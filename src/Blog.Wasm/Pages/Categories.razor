@page "/categories"
@layout MainLayout
@inject IContentService Content
@inject IOptions<SiteSettings> SiteOptions

<OgMeta Title="Categories"
        Description="Toutes les catégories"
        Url="/categories" />

<PageTitle>Categories — @SiteOptions.Value.Title</PageTitle>

<section class="tags-page">
    <h1 class="page-title">Categories</h1>

    @if (_categories is null)
    {
        <p class="loading">Chargement…</p>
    }
    else if (_categories.Count == 0)
    {
        <p>Aucune catégorie trouvée.</p>
    }
    else
    {
        <div class="tag-cloud">
            @foreach (var (category, count) in _categories)
            {
                <a href="/categories/@category" class="tag tag-size-@GetSize(count)">
                    @category <span class="tag-count">(@count)</span>
                </a>
            }
        </div>
    }
</section>

@code {
    private IReadOnlyDictionary<string, int>? _categories;
    private int _maxCount = 1;

    protected override async Task OnInitializedAsync()
    {
        _categories = await Content.GetCategoriesAsync();
        if (_categories.Count > 0)
            _maxCount = _categories.Values.Max();
    }

    private int GetSize(int count)
    {
        if (_maxCount <= 1) return 1;
        var ratio = (double)count / _maxCount;
        return ratio switch
        {
            >= 0.8 => 4,
            >= 0.5 => 3,
            >= 0.2 => 2,
            _      => 1
        };
    }
}
