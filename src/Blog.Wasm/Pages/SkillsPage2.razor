@page "/skills"
@layout MainLayout
@inject IOptions<SiteSettings> SiteOptions
@inject HttpClient Http

<OgMeta Title="Skills"
        Description="Compétences techniques"
        Url="/skills" />

<PageTitle>Skills — @SiteOptions.Value.Title</PageTitle>

<section class="skills-page">
    <h1 class="page-title">Skills</h1>

    @if (_skills is null)
    {
        <p class="loading">Chargement…</p>
    }
    else
    {
        <div class="skill-grid-flat">
            @foreach (var skill in _skills)
            {
                <div class="skill-card">
                    @if (!string.IsNullOrEmpty(skill.Icon))
                    {
                        <img src="@skill.Icon" alt="@skill.Name" class="skill-card-icon" loading="lazy" />
                    }
                    <span class="skill-card-name">@skill.Name</span>
                </div>
            }
        </div>
    }
</section>

@code {
    private List<SkillItem>? _skills;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _skills = await Http.GetFromJsonAsync<List<SkillItem>>("data/skills.json");
        }
        catch
        {
            _skills = [];
        }
    }

    private record SkillItem(string Name, string? Icon);
}
