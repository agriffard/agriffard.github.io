@page "/archives"
@layout MainLayout
@inject IContentService Content
@inject IOptions<SiteSettings> SiteOptions
@inject IOptions<ContentSettings> ContentOptions

<OgMeta Title="Archives"
        Description="Tous les articles par année"
        Url="/archives" />

<PageTitle>Archives — @SiteOptions.Value.Title</PageTitle>

<section class="archives">
    <h1 class="page-title">Archives</h1>

    @if (_archives is null)
    {
        <p class="loading">Chargement…</p>
    }
    else
    {
        @foreach (var (year, posts) in _archives)
        {
            <div class="archive-year">
                <h2>@year <span class="count">(@posts.Count)</span></h2>
                <ul class="archive-list">
                    @foreach (var post in posts)
                    {
                        <li>
                            <time datetime="@post.PubDatetime.ToString("yyyy-MM-dd")">
                                @post.PubDatetime.ToString("dd MMM", System.Globalization.CultureInfo.GetCultureInfo("fr-FR"))
                            </time>
                            <a href="/posts/@post.Slug">@post.Title</a>
                        </li>
                    }
                </ul>
            </div>
        }
    }
</section>

@code {
    private IReadOnlyDictionary<int, IReadOnlyList<PostMeta>>? _archives;

    protected override async Task OnInitializedAsync()
    {
        _archives = await Content.GetArchivesAsync();
    }
}
