@page "/posts/{Slug}"
@layout MainLayout
@inject IContentService Content
@inject IOptions<ContentSettings> ContentOptions
@inject IOptions<SiteSettings> SiteOptions
@inject IOptions<FeatureFlags> Features
@inject IJSRuntime JS

@if (_post is null)
{
    @if (_notFound)
    {
        <h1>Article introuvable</h1>
        <p>L'article demandé n'existe pas.</p>
    }
    else
    {
        <p class="loading">Chargement…</p>
    }
}
else
{
    <OgMeta Title="@_post.Meta.Title"
            Description="@_post.Meta.Description"
            Url="@($"/posts/{_post.Meta.Slug}")"
            Image="@_post.Meta.Cover" />

    <PageTitle>@_post.Meta.Title — @SiteOptions.Value.Title</PageTitle>

    <article class="post-detail">
        <header class="post-header">
            <h1>@_post.Meta.Title</h1>
            <div class="post-meta">
                <time datetime="@_post.Meta.PubDatetime.ToString("yyyy-MM-dd")">
                    <svg class="icon-calendar" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    @_post.Meta.PubDatetime.ToString(ContentOptions.Value.DateFormat, System.Globalization.CultureInfo.GetCultureInfo("fr-FR"))
                </time>
                @if (!string.IsNullOrEmpty(_post.Meta.Author))
                {
                    <span>&nbsp;· @_post.Meta.Author</span>
                }
                @if (Features.Value.ReadingTime && _post.Meta.ReadingTime > 0)
                {
                    <span> · @_post.Meta.ReadingTime min de lecture</span>
                }
            </div>
            @if (_post.Meta.Tags.Count > 0)
            {
                <div class="post-tags">
                    @foreach (var tag in _post.Meta.Tags)
                    {
                        <a href="/tags/@tag" class="tag">@tag</a>
                    }
                </div>
            }
        </header>

        <div class="post-layout">
            <TableOfContents Html="@_post.Html" />
            <div class="post-content prose">
                @((MarkupString)_post.Html)
            </div>
        </div>
    </article>
}

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    private Post? _post;
    private bool _notFound;

    protected override async Task OnParametersSetAsync()
    {
        _post = await Content.GetPostAsync(Slug);
        _notFound = _post is null;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_post is not null)
        {
            await JS.InvokeVoidAsync("highlightAndAddCopyButtons");
        }
    }
}
