@inject IOptions<ContentSettings> ContentOptions
@inject IOptions<FeatureFlags> FeaturesOptions

<article class="article-card">
    @if (!string.IsNullOrEmpty(Meta.Cover) && !Meta.Cover.StartsWith("og/"))
    {
        <a href="/posts/@Meta.Slug" class="article-card-cover">
            <img src="@Meta.Cover" alt="@Meta.Title" loading="lazy" />
        </a>
    }
    <div class="article-card-body">
        <h2 class="article-card-title">
            <a href="/posts/@Meta.Slug">@Meta.Title</a>
        </h2>
        <div class="article-card-meta">
            <time datetime="@Meta.PubDatetime.ToString("yyyy-MM-dd")">
                <svg class="icon-calendar" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                @Meta.PubDatetime.ToString(ContentOptions.Value.DateFormat, System.Globalization.CultureInfo.GetCultureInfo("fr-FR"))
            </time>
            @if (FeaturesOptions.Value.ReadingTime && Meta.ReadingTime > 0)
            {
                <span class="reading-time"> · @Meta.ReadingTime min de lecture</span>
            }
        </div>
        @if (!string.IsNullOrEmpty(Meta.Description))
        {
            <p class="article-card-excerpt">@Meta.Description</p>
        }
        @if (Meta.Tags.Count > 0)
        {
            <div class="article-card-tags">
                @foreach (var tag in Meta.Tags)
                {
                    <a href="/tags/@tag" class="tag">@tag</a>
                }
            </div>
        }
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public PostMeta Meta { get; set; } = default!;
}
